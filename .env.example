# Copy to .env (gitignored) and fill in. Sourced by scripts/launch-wsl.sh.

# Android phone IP and port (WiFi ADB). After reboot, re-check with:
#   adb devices           (Windows side)
# If the phone got a new port, run:
#   adb tcpip 5555        (then re-connect)
PHONE_IP=192.168.1.95
CONNECT_PORT=32831

# Pairing port (one-shot, only when first pairing on a new router)
PAIR_PORT=38351
PAIR_CODE=

# Windows host ADB server
ADB_SERVER_PORT=5037

# Which account config to launch by default
ACCOUNT_NAME=glowofsin

# Path to moneymaker2 queue root (for posting jobs)
MONEYMAKER_QUEUE_ROOT=/home/devil/git/moneymaker2/queue
